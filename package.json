{
  "name": "magpie",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@magpie/orchestrator",
    "dev": "npm run dev --workspace=@magpie/orchestrator",
    "start": "npm run start --workspace=@magpie/orchestrator",
    "test": "npm run test --workspaces --if-present",
    "dev:smee": "node --env-file-if-exists=.env scripts/dev-smee.mjs",
    "build:reviewer-image": "bash scripts/build-reviewer-image.sh"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^22.15.0",
    "tsx": "^4.19.2",
    "smee-client": "^5.0.0"
  }
}
