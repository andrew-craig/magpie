# Magpie orchestrator secrets.
#
# Copy this file to `.env` (repo root, git-ignored) and fill it in. The npm
# `dev` and `start` scripts load it automatically via Node's built-in
# `--env-file-if-exists`, so no dotenv dependency is needed. In production,
# prefer a systemd `EnvironmentFile=` pointing at a root-owned, chmod-600 file
# outside the repo instead of committing anything here.
#
# These deliberately live in the environment, NOT in config.toml, so the
# config file never holds a secret. See config.example.toml and
# packages/orchestrator/src/config.ts for how they are consumed.

# GitHub App webhook secret — verifies the X-Hub-Signature-256 header on
# incoming webhook deliveries. Required.
MAGPIE_WEBHOOK_SECRET=

# NOTE (M4-C): there is deliberately no MAGPIE_LLM_API_KEY here. This
# orchestrator no longer loads a real LLM provider key at all — it mints a
# short-lived, budget-capped virtual key per review job against the gateway's
# management plane instead (see MAGPIE_GATEWAY_MASTER_KEY below). The real
# OpenRouter key lives ONLY in the separate gateway process's OWN env
# (MAGPIE_GATEWAY_OPENROUTER_KEY — see packages/gateway/README.md), which is
# not this file and not this process.

# Bearer token this orchestrator uses to authenticate to the M4 LLM gateway's
# management plane when minting/revoking each job's virtual key (see
# config.example.toml's [gateway] section and packages/gateway/README.md).
# Required. This MUST be the same value the gateway process is started with as
# its own MAGPIE_GATEWAY_MASTER_KEY — one shared secret known to both
# processes. It is NOT the real OpenRouter key (that is the gateway process's
# MAGPIE_GATEWAY_OPENROUTER_KEY, which this orchestrator never sees).
MAGPIE_GATEWAY_MASTER_KEY=

# NOTE: the GitHub App private key is NOT set here. Keep the .pem on disk and
# point `github.private_key_path` in config.toml at it. (The
# MAGPIE_GITHUB_PRIVATE_KEY env var can override that path if you ever need to
# inline the PEM, e.g. in a container, but the file-path approach is preferred.)
